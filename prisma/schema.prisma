// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  DOCTOR
  RECEPTIONIST
  AUXILIARY
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum ReminderType {
  WHATSAPP
  EMAIL
  SMS
}

enum SubscriptionPlan {
  BASIC
  PRO
  CLINIC
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

enum RefundStatus {
  PENDING
  COMPLETED
  REJECTED
}

enum TreatmentPlanStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  PARTIAL
}

enum TreatmentPlanItemStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PrescriptionStatus {
  DRAFT
  DOCTOR_SIGNED
  PATIENT_SIGNED
  FINALIZED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  CANCELLED
  OVERDUE
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  OTHER
}


model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  phone     String?
  email     String?
  address   String?
  timezone  String?
  currency  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[]
  professionals   Professional[]
  patients        Patient[]
  appointmentTypes AppointmentType[]
  appointments    Appointment[]
  subscriptions    Subscription[]
  invoices         Invoice[]
  treatmentPlans   TreatmentPlan[]
  prescriptions    Prescription[]
}

model User {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  email     String   @unique
  password  String
  role      UserRole

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model Professional {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  specialty String?
  email     String?
  phone     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  appointments  Appointment[]
  schedules     Schedule[]
  prescriptions Prescription[]
}

model Patient {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  phone     String?
  email     String?
  birthdate DateTime?
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  appointments   Appointment[]
  invoices       Invoice[]
  treatmentPlans TreatmentPlan[]
  prescriptions  Prescription[]
}

model AppointmentType {
  id              String  @id @default(uuid())
  tenantId        String
  name            String
  durationMinutes Int
  price           Float?

  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  appointments Appointment[]
}

model Appointment {
  id               String            @id @default(uuid())
  tenantId         String
  patientId        String
  professionalId   String
  appointmentTypeId String

  startTime DateTime
  endTime   DateTime
  status    AppointmentStatus

  notes String?

  createdAt DateTime @default(now())

  tenant           Tenant          @relation(fields: [tenantId], references: [id])
  patient          Patient         @relation(fields: [patientId], references: [id])
  professional     Professional    @relation(fields: [professionalId], references: [id])
  appointmentType  AppointmentType @relation(fields: [appointmentTypeId], references: [id])

  reminders        Reminder[]
  invoice          Invoice?
  prescription     Prescription?
  treatmentPlanItem TreatmentPlanItem?
}

model Schedule {
  id             String @id @default(uuid())
  professionalId String

  dayOfWeek Int
  startTime String
  endTime   String

  professional Professional @relation(fields: [professionalId], references: [id])
}

model Reminder {
  id            String       @id @default(uuid())
  appointmentId String
  type          ReminderType
  sentAt        DateTime?
  status        String?

  appointment Appointment @relation(fields: [appointmentId], references: [id])
}

model Subscription {
  id        String              @id @default(uuid())
  tenantId  String
  plan      SubscriptionPlan
  status    SubscriptionStatus

  startedAt DateTime
  expiresAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model TokenBlacklist {
  id         String   @id @default(uuid())
  tokenHash  String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([expiresAt])
}

model Invoice {
  id            String        @id @default(uuid())
  tenantId      String
  patientId     String
  appointmentId String?       @unique

  status          InvoiceStatus @default(DRAFT)
  issuedAt        DateTime?
  dueDate         DateTime?
  notes           String?
  treatmentPlanId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  patient       Patient        @relation(fields: [patientId], references: [id])
  appointment   Appointment?   @relation(fields: [appointmentId], references: [id])
  treatmentPlan TreatmentPlan? @relation(fields: [treatmentPlanId], references: [id])

  items    InvoiceItem[]
  payments Payment[]
  refunds  Refund[]
}

model InvoiceItem {
  id                  String  @id @default(uuid())
  invoiceId           String
  treatmentPlanItemId String?
  description         String
  quantity            Int     @default(1)
  unitPrice           Float
  total               Float

  invoice           Invoice            @relation(fields: [invoiceId], references: [id])
  treatmentPlanItem TreatmentPlanItem? @relation(fields: [treatmentPlanItemId], references: [id])
}

model Payment {
  id        String        @id @default(uuid())
  invoiceId String
  amount    Float
  method    PaymentMethod
  reference String?
  paidAt    DateTime      @default(now())

  invoice Invoice  @relation(fields: [invoiceId], references: [id])
  refunds Refund[]
}

model Refund {
  id        String        @id @default(uuid())
  paymentId String
  invoiceId String
  amount    Float
  reason    String?
  method    PaymentMethod
  status    RefundStatus  @default(PENDING)
  createdAt DateTime      @default(now())

  payment Payment @relation(fields: [paymentId], references: [id])
  invoice Invoice @relation(fields: [invoiceId], references: [id])
}

model TreatmentPlan {
  id        String              @id @default(uuid())
  tenantId  String
  patientId String
  title     String
  notes     String?
  status    TreatmentPlanStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant              @relation(fields: [tenantId], references: [id])
  patient Patient             @relation(fields: [patientId], references: [id])
  items   TreatmentPlanItem[]
  invoices Invoice[]
}

model TreatmentPlanItem {
  id              String                  @id @default(uuid())
  treatmentPlanId String
  description     String
  price           Float
  status          TreatmentPlanItemStatus @default(PENDING)
  appointmentId   String?                 @unique
  notes           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  treatmentPlan TreatmentPlan @relation(fields: [treatmentPlanId], references: [id])
  appointment   Appointment?  @relation(fields: [appointmentId], references: [id])
  invoiceItems  InvoiceItem[]
}

model Prescription {
  id             String             @id @default(uuid())
  tenantId       String
  patientId      String
  professionalId String
  appointmentId  String?            @unique
  diagnosis      String?
  notes          String?
  status         PrescriptionStatus @default(DRAFT)

  doctorSignature  String?
  patientSignature String?
  fingerprint      String?
  finalizedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  patient      Patient      @relation(fields: [patientId], references: [id])
  professional Professional @relation(fields: [professionalId], references: [id])
  appointment  Appointment? @relation(fields: [appointmentId], references: [id])

  items PrescriptionItem[]
}

model PrescriptionItem {
  id             String @id @default(uuid())
  prescriptionId String
  medication     String
  dosage         String
  frequency      String
  duration       String?
  instructions   String?

  prescription Prescription @relation(fields: [prescriptionId], references: [id])
}